APP_NAME=Resonance
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---- Base de données : Postgres (service Docker `postgres`) ----
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=resonance
DB_USERNAME=resonance
DB_PASSWORD=resonance

# ---- Sessions / cache / queue ----
# Starter : tout en database/sync pour matérialiser la dette de perf.
# @perf-debt: queue=sync, cache=database — résolus en J3 atelier
# "laravel-redis-queues".
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ---- Redis (configuré mais inutilisé en starter — atelier J3 l'activera) ----
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Mail : Mailpit (service Docker `mailpit`) ----
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@resonance.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Stockage S3 : MinIO (service Docker `minio`) --------------------------
AWS_ACCESS_KEY_ID=resonance
AWS_SECRET_ACCESS_KEY=resonance-secret
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=resonance
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://minio:9000
# URL publique pour le frontend (depuis le navigateur de l'host).
AWS_URL=http://localhost:9000/resonance

# ---- Sanctum (token-based, cf. resonance-spec.md §2) -----------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

VITE_APP_NAME="${APP_NAME}"
