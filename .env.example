# =============================================================================
# Resonance — variables d'environnement
# =============================================================================
# Copier ce fichier en `.env` puis ajuster si besoin.
#   cp .env.example .env
#
# Ce fichier alimente `docker-compose.yml` (substitution ${VAR}).
# Les services applicatifs (Laravel, Nuxt) auront leur propre .env dans
# backend/ et frontend/ aux phases suivantes.
# =============================================================================

# ---- Projet ----
COMPOSE_PROJECT_NAME=resonance

# ---- PostgreSQL ----
POSTGRES_DB=resonance
POSTGRES_USER=resonance
POSTGRES_PASSWORD=resonance
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO ----
# Les credentials root servent à l'admin et au bootstrap du bucket.
# Pour l'app Laravel, on créera plus tard un user/policy dédié.
MINIO_ROOT_USER=resonance
MINIO_ROOT_PASSWORD=resonance-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=resonance
# Région factice — requise par certains SDK S3
MINIO_REGION=eu-west-3

# ---- Mailpit ----
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ---- Backend Laravel ----
# UID/GID de ton utilisateur host : `id -u` / `id -g` (1000 par défaut sur Linux).
# Aligne les permissions des fichiers générés (vendor/, storage/, migrations).
UID=1000
GID=1000
# BACKEND_PORT supprimé en Phase 4-bis : le backend est en mode FPM (FastCGI),
# il n'écoute plus en HTTP. Tout passe par Nginx (NGINX_PORT).

# ---- Frontend Nuxt ----
FRONTEND_PORT=3000

# ---- Nginx frontal (Phase 4-bis) ----
# Port HTTP exposé sur l'host. Toute l'app (Nuxt SSR + API Laravel) est
# accessible derrière ce port unique. Cf. infra/nginx/.
NGINX_PORT=8080
