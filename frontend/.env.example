# =============================================================================
# Resonance — frontend Nuxt (variables d'environnement)
# =============================================================================
# Copier en `.env` puis ajuster si besoin. Ces variables sont consommées par
# `nuxt.config.ts` via `runtimeConfig`.
#
# Phase 4-bis : la stack tourne derrière Nginx (port 8080) ; le backend FPM
# n'est plus accessible en HTTP direct, tout passe par le frontal.
# =============================================================================

# API Laravel
# - NUXT_API_BASE_INTERNAL : URL utilisée côté SSR (réseau Docker → Nginx).
# - NUXT_PUBLIC_API_BASE   : URL utilisée côté client (browser → Nginx host).
#   Le port doit correspondre à NGINX_PORT du `.env` racine (défaut 8080).
NUXT_API_BASE_INTERNAL=http://nginx/api/v1
NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1

# Médias servis directement par MinIO (anonymous download activé sur le bucket).
NUXT_PUBLIC_MEDIA_BASE=http://localhost:9000/resonance
